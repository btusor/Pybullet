<?xml version="1.0" encoding="utf-8"?>
<robot name="CS612urdf">

  <link name="base_link">
    <visual><geometry><mesh filename="base_link.STL"/></geometry></visual>
    <collision><geometry><mesh filename="base_link.STL"/></geometry></collision>
    <inertial>
      <mass value="0.948882914788405"/>
      <inertia ixx="0.0029607" ixy="0" ixz="0" iyy="0.0026222" iyz="0" izz="0.0039906"/>
    </inertial>
  </link>

  <link name="link1">
    <visual><geometry><mesh filename="link1.STL"/></geometry></visual>
    <collision><geometry><mesh filename="link1.STL"/></geometry></collision>
  </link>
  <joint name="Joint1" type="revolute">
    <parent link="base_link"/><child link="link1"/>
    <origin xyz="0 0 0.193" rpy="0 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="200" velocity="2.0"/>
  </joint>

  <link name="link2">
    <visual><geometry><mesh filename="link2.STL"/></geometry></visual>
    <collision><geometry><mesh filename="link2.STL"/></geometry></collision>
  </link>
